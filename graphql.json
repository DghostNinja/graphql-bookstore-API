{
  "info": {
    "name": "GraphQL Bookstore API",
    "description": "A realistic GraphQL Bookstore API for testing security vulnerabilities.\n\n## API Flow (Real Bookstore)\n1. Public: Browse books, view details, read reviews\n2. Auth: Register → Login → Get token\n3. Cart: Add items, apply coupon, view cart\n4. Checkout: Pay card → Order created + payment processed\n5. Orders: View, cancel\n6. Reviews: Create for purchased books\n\n## Setup\n1. Import collection into Postman\n2. Set `base_url` (default: http://localhost:4000)\n3. Run requests in flow order\n4. Authenticate: Login → copy token to `token` variable\n\n## Available Coupons\n| Code | Type | Value | Min Order |\n|------|------|-------|----------|\n| WELCOME10 | percentage | 10% | $0 |\n| FLAT20 | fixed | $20 | $100 |\n| SUMMER25 | percentage | 25% | $50 |\n| DISCOUNT10 | percentage | 10% | $0 |\n\n## Default Credentials\n| Username | Password | Role |\n|----------|----------|-------|\n| admin | password123 | admin |\n| staff | password123 | staff |\n| user | password123 | user |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "username",
      "value": "newuser",
      "type": "string"
    },
    {
      "key": "password",
      "value": "test123",
      "type": "string"
    },
    {
      "key": "firstName",
      "value": "John",
      "type": "string"
    },
    {
      "key": "lastName",
      "value": "Doe",
      "type": "string"
    },
    {
      "key": "bookId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "quantity",
      "value": "1",
      "type": "string"
    },
    {
      "key": "couponCode",
      "value": "SUMMER25",
      "type": "string"
    },
    {
      "key": "rating",
      "value": "5",
      "type": "string"
    },
    {
      "key": "comment",
      "value": "Great book!",
      "type": "string"
    },
    {
      "key": "reviewId",
      "value": "",
      "type": "string"
    },
    {
      "key": "webhookId",
      "value": "",
      "type": "string"
    },
    {
      "key": "webhookUrl",
      "value": "http://example.com/webhook",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cardNumber",
      "value": "4111111111111111",
      "type": "string"
    },
    {
      "key": "cardExpiry",
      "value": "12/25",
      "type": "string"
    },
    {
      "key": "cardCvv",
      "value": "123",
      "type": "string"
    },
    {
      "key": "search",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Public - Browse Books",
      "item": [
        {
          "name": "List All Books",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ books { id title author { firstName lastName } price stockQuantity category { name } isFeatured isBestseller } }\"}"
            }
          }
        },
        {
          "name": "Get Book Details",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ book(id: {{bookId}}) { id title author { firstName lastName } price description isbn stockQuantity category { name } } }\"}"
            }
          }
        },
        {
          "name": "Search Books",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ books(search: \\\"{{search}}\\\") { id title author { firstName } price } }\"}"
            }
          }
        },
        {
          "name": "View Book Reviews",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ bookReviews(bookId: {{bookId}}) { id rating comment user { username } createdAt } }\"}"
            }
          }
        },
        {
          "name": "Schema Introspection",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ __schema { types { name fields { name args { name type { name } } } } }\"}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Authentication",
      "item": [
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { register(username: \\\"{{username}}\\\", firstName: \\\"{{firstName}}\\\", lastName: \\\"{{lastName}}\\\", password: \\\"{{password}}\\\") { success message } }\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
"raw": "{\"query\":\"mutation { login(username: \\\"{{username}}\\\", password: \\\"{{password}}\\\") { success token user { id username role firstName lastName } } }\"}"
            }
          },
          {
            "name": "Forgot Password",
            "request": {
              "method": "POST",
              "url": "{{base_url}}/graphql",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\"query\":\"mutation { forgotPassword(username: \\\"{{username}}\\\", newPassword: \\\"{{password}}\\\") { success message } }\"}"
              }
            }
          },
          {
            "name": "Get Current User (Me)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ me { id username firstName lastName role email phone address city state country } }\"}"
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { updateProfile(firstName: \\\"{{firstName}}\\\", lastName: \\\"{{lastName}}\\\") { success message } }\"}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Shopping Cart",
      "item": [
        {
          "name": "View Cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ cart { id items { id book { id title author { firstName } price } quantity } subtotal tax shipping discount couponCode total } }\"}"
            }
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { addToCart(bookId: {{bookId}}, quantity: {{quantity}}) { success message } }\"}"
            }
          }
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { removeFromCart(bookId: {{bookId}}) { success message } }\"}"
            }
          }
        },
        {
          "name": "Apply Coupon",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { applyCoupon(code: \\\"{{couponCode}}\\\") { success message discountAmount couponCode } }\"}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Checkout & Payment",
      "item": [
        {
          "name": "Checkout - Pay & Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { checkout(cardNumber: \\\"{{cardNumber}}\\\", expiry: \\\"{{cardExpiry}}\\\", cvv: \\\"{{cardCvv}}\\\") { success orderId orderNumber totalAmount warning payment { success message transactionId } } }\"}"
            }
          }
        }
      ]
    },
    {
      "name": "5. Orders",
      "item": [
        {
          "name": "View My Orders",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ orders { id orderNumber status totalAmount paymentStatus createdAt items { id book { id title } quantity unitPrice } } }\"}"
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { cancelOrder(orderId: \\\"{{orderId}}\\\") { success message } }\"}"
            }
          }
        }
      ]
    },
    {
      "name": "6. Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { createReview(bookId: {{bookId}}, rating: {{rating}}, comment: \\\"{{comment}}\\\") { success message } }\"}"
            }
          }
        },
        {
          "name": "My Reviews",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ myReviews { id rating comment book { id title } createdAt } }\"}"
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { deleteReview(reviewId: {{reviewId}}) { success message } }\"}"
            }
          }
        }
      ]
    },
    {
      "name": "7. Webhooks",
      "item": [
        {
          "name": "Register Webhook",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { registerWebhook(url: \\\"{{webhookUrl}}\\\", events: [\\\"order.created\\\", \\\"order.paid\\\", \\\"order.cancelled\\\", \\\"payment.completed\\\"], secret: \\\"mysecret\\\") { success message webhook { id url events isActive } } }\"}"
            }
          }
        },
        {
          "name": "View My Webhooks",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"{ webhooks { id url events isActive createdAt } }\"}"
            }
          }
        },
        {
          "name": "Test Webhook",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/graphql",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { testWebhook(webhookId: \\\"{{webhookId}}\\\") { success message } }\"}"
            }
          }
        }
      ]
    }
  ]
}